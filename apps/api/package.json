{
  "name": "@hymea/api",
  "version": "0.0.0",
  "private": true,
  "description": "API HYMEA (NestJS + Kysely) : auth, RDV, disponibilités, emails, cron.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "jest --runInBand",
    "migrate": "ts-node -P tsconfig.json src/database/migrate.ts up",
    "migrate:down": "ts-node -P tsconfig.json src/database/migrate.ts down",
    "migrate:make": "ts-node -P tsconfig.json src/database/migrate.ts make"
  },
  "dependencies": {
    "@hymea/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
