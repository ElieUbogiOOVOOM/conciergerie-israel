# ─────────────────────────────────────────────────────────────────────────────
# HYMEA — variables d'environnement (exemple)
# Copier en `.env` pour le développement local. NE PAS committer de `.env`.
# En production, ces valeurs sont définies dans Dockploy (issue #46).
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (docker-compose local) ---
POSTGRES_USER=hymea
POSTGRES_PASSWORD=hymea
POSTGRES_DB=hymea
POSTGRES_PORT=5432

# --- API NestJS ---
NODE_ENV=development
API_PORT=4000
# URL de connexion consommée par Kysely (apps/api).
# Local : pointe vers le postgres de docker-compose.
# Prod  : surchargée par Dockploy (réseau interne, ex. hymea-db-xxxxxx:5432).
DATABASE_URL=postgresql://hymea:hymea@localhost:5432/hymea
