# ─────────────────────────────────────────────────────────────────────────────
# HYMEA — variables d'environnement (exemple)
# Copier en `.env` pour le développement local. NE PAS committer de `.env`.
# En production, ces valeurs sont définies dans Dockploy (issue #46).
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (docker-compose local) ---
POSTGRES_USER=hymea
POSTGRES_PASSWORD=hymea
POSTGRES_DB=hymea
POSTGRES_PORT=5432

# --- API NestJS ---
NODE_ENV=development
API_PORT=4000
# URL de connexion consommée par Kysely (apps/api).
# Local : pointe vers le postgres de docker-compose.
# Prod  : surchargée par Dockploy (réseau interne, ex. hymea-db-xxxxxx:5432).
DATABASE_URL=postgresql://hymea:hymea@localhost:5432/hymea

# --- Auth / JWT (issue #9) ---
# Secrets de signature OBLIGATOIRES (≥ 32 caractères), DISTINCTS l'un de l'autre.
# En production le boot ÉCHOUE si une valeur faible/par défaut (« change-me », « secret »…)
# est détectée. Générer : `openssl rand -base64 48`.
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please
# Durée de vie de l'access token (format jsonwebtoken) et du refresh token (jours).
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
# Pose le cookie refresh avec l'attribut Secure (false en HTTP local ; DOIT valoir true en prod).
COOKIE_SECURE=false

# --- Disponibilités & créneaux (issue #12) ---
BUSINESS_TZ=Asia/Jerusalem
DEFAULT_SLOT_MINUTES=60

# --- Rate-limit global (toutes routes) & anti-brute-force auth ---
# Fenêtre (s) et nombre de requêtes/IP. AUTH_* protège login/refresh du bourrage d'identifiants.
API_THROTTLE_TTL=60
API_THROTTLE_LIMIT=120
AUTH_THROTTLE_TTL=900
AUTH_THROTTLE_LIMIT=10

# --- RDV public : anti-spam (issue #13) ---
# Secret Cloudflare Turnstile. Vide = vérification désactivée (dev/staging) ;
# OBLIGATOIRE en production (le boot échoue sinon).
TURNSTILE_SECRET=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# Rate-limit IP sur la demande publique : LIMIT requêtes par fenêtre de TTL secondes.
RDV_THROTTLE_TTL=60
RDV_THROTTLE_LIMIT=5
# Version du texte de consentement RGPD (horodaté sur chaque RDV).
CONSENT_VERSION=2026-06-v1

# --- Emails transactionnels (issue #16) ---
# Clé API Resend. Laisser vide en local : les emails sont journalisés au lieu d'être envoyés.
RESEND_API_KEY=
MAIL_FROM=HYMEA <no-reply@hymea.com>
HYMEA_NOTIFICATION_EMAIL=contact@hymea.com
PUBLIC_SITE_URL=https://hymea.com

# --- Vitrine Next.js (apps/web, issues #28 & #29) ---
# Base de l'API consommée par le funnel RDV depuis le navigateur (exposée au client).
# Local : http://localhost:4000/api — Prod : http://hymea.elie-ubogi.fr/api.
NEXT_PUBLIC_API_URL=http://hymea.elie-ubogi.fr/api
# Site key Cloudflare Turnstile (publique). Laisser vide pour désactiver le widget
# côté front (le honeypot reste actif ; le back skippe la vérif si TURNSTILE_SECRET vide).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Back-office Next.js (apps/admin, issues #32 & #33) ---
# Le back-office (servi sous /admin, port :3001 en dev) consomme l'API via la même
# variable NEXT_PUBLIC_API_URL que la vitrine. En prod, admin & API sont same-origin
# (reverse-proxy) : la base relative /api du client admin suffit même si la variable
# pointe ailleurs pour la vitrine.
# Origines autorisées en CORS (CSV) pour le dev cross-origin admin/web → API.
# Laisser vide en prod (same-origin). Local : http://localhost:3001,http://localhost:3000.
CORS_ORIGINS=

# --- Seed admin (CLI : pnpm --filter @hymea/api seed:admin) ---
# Alternative aux flags --email / --password.
# Mot de passe : ≥ 12 caractères, non trivial (les valeurs « change-me/admin/hymea » sont refusées).
SEED_ADMIN_EMAIL=admin@hymea.com
SEED_ADMIN_PASSWORD=change-me-please
